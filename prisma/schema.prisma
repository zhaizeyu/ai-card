generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Card {
  id          String   @id @default(cuid())
  prompt      String
  name        String
  race        String?
  element     String
  rarity      String
  hp          Int
  atk         Int
  def         Int
  spd         Int
  powerScore  Int
  skillName   String
  skillText   String
  skillType   String
  trigger     String
  condition   String
  selector    String
  effect      String
  effectPower Int
  cooldown    Int      @default(0)
  description String
  imageUrl    String?
  level       Int      @default(1)
  exp         Int      @default(0)
  wins        Int      @default(0)
  losses      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  battlesAsPlayer Battle[]    @relation("PlayerCard")
  battlesAsEnemy   Battle[]    @relation("EnemyCard")
  worldCards       WorldCard[]
}

model Battle {
  id           String   @id @default(cuid())
  playerCardId String
  enemyCardId  String?
  result       String
  winnerCardId String?
  loserCardId  String?
  battleLog    String
  rewardJson   String?
  createdAt    DateTime @default(now())

  playerCard Card  @relation("PlayerCard", fields: [playerCardId], references: [id])
  enemyCard  Card? @relation("EnemyCard", fields: [enemyCardId], references: [id])
}

model GenerationLog {
  id        String   @id @default(cuid())
  prompt    String
  rawOutput String?
  status    String
  error     String?
  createdAt DateTime @default(now())
}

model ComponentReward {
  id          String   @id @default(cuid())
  name        String
  type        String
  rarity      String
  description String
  effect      String
  cost        Int
  createdAt   DateTime @default(now())
}

model World {
  id          String   @id @default(cuid())
  name        String
  theme       String
  description String?
  day         Int      @default(1)
  prosperity  Int      @default(30)
  safety      Int      @default(30)
  resource    Int      @default(30)
  chaos       Int      @default(10)
  fame        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cards  WorldCard[]
  events WorldEvent[]
}

model WorldCard {
  id       String   @id @default(cuid())
  worldId  String
  cardId   String
  role     String
  joinedAt DateTime @default(now())

  world World @relation(fields: [worldId], references: [id])
  card  Card  @relation(fields: [cardId], references: [id])
}

model WorldEvent {
  id          String   @id @default(cuid())
  worldId     String
  day         Int
  type        String
  title       String
  description String
  status      String   @default("pending")
  result      String?
  createdAt   DateTime @default(now())

  world World @relation(fields: [worldId], references: [id])
}
