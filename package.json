{
  "name": "ai-monster-card-game",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "dev:start": "sh scripts/dev-start.sh",
    "dev:stop": "sh scripts/dev-stop.sh",
    "dev:restart": "npm run dev:stop && npm run dev:start",
    "dev:status": "sh scripts/dev-status.sh",
    "app:start": "npm run dev:start",
    "app:stop": "npm run dev:stop",
    "app:restart": "npm run dev:restart",
    "app:status": "npm run dev:status",
    "build": "prisma generate && vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@types/express": "^5.0.6",
    "@vitejs/plugin-react": "^6.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "prisma": "^6.10.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.0",
    "tailwind-merge": "^2.5.5",
    "tsx": "^4.22.4",
    "vite": "^8.0.16",
    "zod": "^3.24.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.1"
  }
}
